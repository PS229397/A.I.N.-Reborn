{
  "agents": {
    "architecture": {
      "command": "gemini",
      "args": [],
      "model": null,
      "description": "Gemini for architecture analysis — run: gemini --version to verify"
    },
    "planning": {
      "command": "codex",
      "args": [],
      "model": null,
      "description": "OpenAI Codex for planning — run: codex --version to verify"
    },
    "task_creation": {
      "command": "claude",
      "args": ["--print"],
      "model": null,
      "description": "ChiefLoop task creation stage — defaults to 'claude --print'. Change 'command' to 'chiefloop' (or your ChiefLoop CLI name) if ChiefLoop is installed."
    },
    "implementation": {
      "command": "claude",
      "args": ["--allowedTools", "Edit,Write,Bash,Read,Glob,Grep"],
      "model": null,
      "description": "Claude Code for implementation with file access"
    }
  },
  "validation": {
    "auto_detect": true,
    "commands": []
  },
  "git": {
    "auto_branch": true,
    "auto_commit": false,
    "branch_prefix": "ai/feature"
  },
  "scan": {
    "ignore_dirs": [
      ".git",
      "node_modules",
      "vendor",
      ".venv",
      "venv",
      "__pycache__",
      ".ai-pipeline",
      "dist",
      "build",
      ".next",
      "coverage",
      ".turbo"
    ],
    "key_files": [
      "package.json",
      "composer.json",
      "requirements.txt",
      "Pipfile",
      "pyproject.toml",
      "Gemfile",
      "go.mod",
      "Cargo.toml",
      "pom.xml",
      "Dockerfile",
      "docker-compose.yml",
      "docker-compose.yaml",
      ".env.example",
      "Makefile",
      "README.md"
    ]
  }
}
