{
  "agents": {
    "architecture": {
      "command": "gemini",
      "args": [],
      "model": null,
      "description": "Gemini for architecture analysis — run: gemini --version to verify"
    },
    "planning": {
      "command": "codex",
      "args": [],
      "model": null,
      "prompt_mode": "arg",
      "description": "OpenAI Codex for planning — run: codex --version to verify"
    },
    "task_creation": {
      "command": "chief",
      "args": [],
      "model": null,
      "description": "Chief autonomous PRD agent — auto-installed by ain init"
    },
    "implementation": {
      "command": "claude",
      "args": ["--allowedTools", "Edit,Write,Bash,Read,Glob,Grep"],
      "model": null,
      "description": "Claude Code for implementation with file access"
    }
  },
  "agent_teams": {
    "enabled": false,
    "max_teammates": 3,
    "lead_model": "claude-opus-4-6",
    "teammate_model": "claude-sonnet-4-6",
    "require_verification": true
  },
  "prd_import": {
    "min_prd_chars": 500,
    "allowed_extensions": [".md", ".txt", ".pdf"]
  },
  "fallback": {
    "enabled": false,
    "trigger_on": "token_limit",
    "notification_timeout_secs": 180,
    "fallback_agent": "codex",
    "fallback_prompt_mode": "full_auto",
    "protected_paths": ["docs/", ".ai-pipeline/", ".git/", "CLAUDE.md", ".claude/"],
    "stages_with_fallback": ["task_creation", "implementation"],
    "codex_timeout_secs": 3600,
    "on_codex_limit": "pause"
  },
  "validation": {
    "auto_detect": true,
    "commands": []
  },
  "git": {
    "auto_branch": true,
    "auto_commit": false,
    "branch_prefix": "ai/feature"
  },
  "scan": {
    "ignore_dirs": [
      ".git",
      "node_modules",
      "vendor",
      ".venv",
      "venv",
      "__pycache__",
      ".ai-pipeline",
      "dist",
      "build",
      ".next",
      "coverage",
      ".turbo"
    ],
    "key_files": [
      "package.json",
      "composer.json",
      "requirements.txt",
      "Pipfile",
      "pyproject.toml",
      "Gemfile",
      "go.mod",
      "Cargo.toml",
      "pom.xml",
      "Dockerfile",
      "docker-compose.yml",
      "docker-compose.yaml",
      ".env.example",
      "Makefile",
      "README.md"
    ]
  }
}
