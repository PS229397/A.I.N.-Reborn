{
  "agents": {
    "architecture": {
      "command": "gemini",
      "args": [],
      "model": "gemini-2.5-flash",
      "description": "Gemini for architecture analysis — run: gemini --version to verify"
    },
    "planning": {
      "command": "codex",
      "args": [],
      "model": "gpt-5.1",
      "prompt_mode": "arg",
      "description": "OpenAI Codex for planning — run: codex --version to verify"
    },
    "planning_codex": {
      "command": "codex",
      "args": [],
      "model": "gpt-5.1",
      "prompt_mode": "arg",
      "description": "OpenAI Codex for planning generation in codex_only mode"
    },
    "planning_chief": {
      "command": "chief",
      "args": [],
      "model": "claude-opus-4.1",
      "description": "Chief planning agent for claude_chief_only mode"
    },
    "task_creation": {
      "command": "chief",
      "args": [],
      "model": "claude-sonnet-4-20250514",
      "description": "Chief autonomous PRD agent — auto-installed by ain init"
    },
    "task_creation_codex": {
      "command": "codex",
      "args": [
        "exec"
      ],
      "model": "gpt-5-codex",
      "prompt_mode": "stdin",
      "description": "OpenAI Codex for task creation in codex_only mode"
    },
    "implementation": {
      "command": "claude",
      "args": [
        "--allowedTools",
        "Edit,Write,Bash,Read,Glob,Grep"
      ],
      "model": "claude-sonnet-4-20250514",
      "description": "Claude Code for implementation with file access — primary (Codex fallback enabled)"
    },
    "implementation_codex": {
      "command": "codex",
      "args": [
        "exec"
      ],
      "model": "gpt-5.1-codex-max",
      "prompt_mode": "stdin",
      "description": "OpenAI Codex for implementation in codex_only mode"
    },
    "implementation_fallback": {
      "command": "codex",
      "args": [
        "--approval-mode", "full-auto"
      ],
      "model": "gpt-5.1-codex-max",
      "prompt_mode": "arg",
      "description": "Codex in full-auto mode — fallback when Claude hits token limit during implementation"
    }
  },
  "pipeline_mode": {
    "default": "default",
    "available": [
      "default",
      "codex_only",
      "claude_chief_only"
    ]
  },
  "validation": {
    "auto_detect": true,
    "commands": []
  },
  "git": {
    "auto_branch": true,
    "auto_commit": false,
    "branch_prefix": "ai/feature"
  },
  "scan": {
    "ignore_dirs": [
      ".git",
      "node_modules",
      "vendor",
      ".venv",
      "venv",
      "__pycache__",
      ".ai-pipeline",
      "dist",
      "build",
      ".next",
      "coverage",
      ".turbo"
    ],
    "key_files": [
      "package.json",
      "composer.json",
      "requirements.txt",
      "Pipfile",
      "pyproject.toml",
      "Gemfile",
      "go.mod",
      "Cargo.toml",
      "pom.xml",
      "Dockerfile",
      "docker-compose.yml",
      "docker-compose.yaml",
      ".env.example",
      "Makefile",
      "README.md"
    ]
  },
  "runtime": {
    "timeouts": {
      "default_seconds": 480,
      "per_stage": {
        "scanning": 180,
        "architecture": 420,
        "planning_questions": 300,
        "planning_generation": 480,
        "task_creation": 360,
        "implementation": 900,
        "validation": 420
      }
    },
    "retries": {
      "max_attempts": 2,
      "backoff_seconds": 5,
      "backoff_multiplier": 1.5,
      "jitter": true,
      "fail_fast": {
        "on_missing_binary": true,
        "on_timeout": false,
        "on_corrupted_state": true
      }
    },
    "cache": {
      "enabled": true,
      "path": ".ai-pipeline/cache",
      "ttl_seconds": 604800,
      "max_entries": 64,
      "respect_cli_no_cache": true
    }
  }
}
